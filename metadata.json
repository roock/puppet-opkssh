{
  "name": "roock-opkssh",
  "version": "0.1.0",
  "author": "Roman Pertl",
  "summary": "Installs and configures opkssh",
  "license": "Apache-2.0",
  "source": "https://github.com/roock/puppet-opkssh",
  "dependencies": [
    {
      "name": "puppet/archive",
      "version_requirement": ">= 2.2.0 < 9.0.0"
    }
  ],
  "operatingsystem_support": [
    {
      "operatingsystem": "Debian",
      "operatingsystemrelease": [
        "10",
        "11",
        "12",
        "13"
      ]
    },
    {

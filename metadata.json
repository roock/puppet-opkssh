        "18.04",
        "20.04",
        "22.04"
      ]
    }
  ],
  "requirements": [
    {
      "name": "openvox",
      "version_requirement": ">= 8.19.0 < 9.0.0"
    }
  ],
  "pdk-version": "3.4.0",
  "template-url": "https://github.com/puppetlabs/pdk-templates#3.4.0",
  "template-ref": "tags/3.4.0-0-gd3cc13f"
